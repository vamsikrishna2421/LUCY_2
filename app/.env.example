EXPO_PUBLIC_AI_MODE=hybrid
# Default: device. Set to ollama-dev only for explicit emulator/laptop development.
EXPO_PUBLIC_LOCAL_INFERENCE=device
# fast = 482 MB on-device model; balanced = 1.09 GB model for later quality benchmarking.
EXPO_PUBLIC_DEVICE_MODEL_TIER=fast
# Development only: optional local URL serving the same model assets to an emulator.
# EXPO_PUBLIC_DEVICE_MODEL_ASSET_BASE_URL=http://localhost:8765
# Legacy development flag retained for earlier validation scripts. The app now
# enables remote GPT-5.4 Nano only after a key is securely saved in Settings.
EXPO_PUBLIC_ALLOW_EXTERNAL_AI=false
# Used only when EXPO_PUBLIC_LOCAL_INFERENCE=ollama-dev.
EXPO_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434
EXPO_PUBLIC_OLLAMA_MODEL=phi3
# Shipped remote provider when user enables it from Settings. Never add an app key here for a shared build.
EXPO_PUBLIC_OPENAI_MODEL=gpt-5.4-nano
EXPO_PUBLIC_OPENAI_SUMMARY_MODEL=gpt-5.4-nano
# Claude settings below are retained for benchmark comparison scripts only.
EXPO_PUBLIC_CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
EXPO_PUBLIC_CLAUDE_SUMMARY_MODEL=claude-sonnet-4-6
# Prototype-only direct Claude connection; do not ship a bundled API key.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Benchmark only: `npm run bench:kaggle-eleanor:claude` redacts credential/card
# values locally before sending eligible synthetic probes to Claude.
# Benchmark only: `npm run bench:kaggle-eleanor:openai` uses the same redaction
# boundary before calling the OpenAI Responses API. Do not bundle this key.
OPENAI_API_KEY=
