# LUCY 2.0 Dashboard — environment variables
# Copy to `.env.local` and fill in. With NONE set, the dashboard runs on realistic MOCK data.

# ── RevenueCat (server-only) ─────────────────────────────────────────────
# Secret API key (v1/v2). Used server-side to fetch subscriptions / MRR.
# https://app.revenuecat.com → Project Settings → API Keys → Secret key
RC_SECRET_KEY=

# Optional: RevenueCat project id (for v2 endpoints). Leave blank for v1.
RC_PROJECT_ID=

# ── PostHog (server-only) ────────────────────────────────────────────────
# Personal API key (NOT the project write key) — needs query/insight read scope.
# https://app.posthog.com → Settings → Personal API Keys
POSTHOG_API_KEY=

# PostHog project id (numeric) — required alongside the API key for queries.
POSTHOG_PROJECT_ID=

# PostHog host. Cloud US: https://us.posthog.com  ·  EU: https://eu.posthog.com
POSTHOG_HOST=https://us.posthog.com

# ── Dashboard auth ───────────────────────────────────────────────────────
# Single shared admin password. If unset, the dashboard is OPEN (dev only).
DASHBOARD_PASSWORD=
